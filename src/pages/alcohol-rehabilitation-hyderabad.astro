---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getServiceLocationSchema } from '@/lib/structured-data';

const structuredData = getServiceLocationSchema(
  "Alcohol Rehabilitation",
  "alcohol-rehabilitation-hyderabad",
  "Professional alcohol rehabilitation and detoxification programs in Hyderabad, Telangana"
);
---

<Layout
  title="Alcohol Rehabilitation Centre in Hyderabad | Janani De-Addiction Centre"
  description="Alcohol rehabilitation and detox treatment in Hyderabad at Janani Centre. Professional medical supervision, counseling, and therapy. Call 6302682285."
  keywords="alcohol rehabilitation hyderabad, alcohol detox center, rehab hyderabad, de-addiction centre, alcohol treatment telangana"
  canonicalUrl="/alcohol-rehabilitation-hyderabad"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/alcohol-rehabilitation-hyderabad" client:load />

    <section class="bg-hero">
      <div class="container py-14 md:py-20">
        <h1 class="text-4xl md:text-5xl">Alcohol Rehabilitation in Hyderabad</h1>
        <p class="mt-4 max-w-prose text-lg text-muted-foreground">
          Professional alcohol detoxification and rehabilitation at Janani. Medical supervision, counseling, and therapy for lasting recovery.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="tel:+916302682285" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90">
            Call Now
          </a>
          <a href="https://wa.me/916302682285" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50">
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-18">
      <div class="container max-w-4xl">
        <h2 class="text-3xl font-bold mb-6">Alcohol Addiction Treatment in Hyderabad</h2>

        <p class="text-muted-foreground leading-relaxed mb-6">
          Janani Alcohol & Drug Rehabilitation Centre specializes in professional alcohol rehabilitation and detoxification treatment in Hyderabad. Our comprehensive program combines medical supervision, psychological counseling, and therapeutic support to help individuals overcome alcohol addiction.
        </p>

        <p class="text-muted-foreground leading-relaxed mb-6">
          Alcohol addiction affects not only the individual but also their family and community. Our evidence-based treatment approach addresses both the physical dependence and the underlying behavioral patterns that contribute to alcohol abuse.
        </p>

        <h3 class="text-2xl font-semibold mt-10 mb-4">Our Alcohol Rehabilitation Program</h3>

        <div class="grid gap-6 md:grid-cols-2 mb-8">
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Medical Detoxification</h4>
            <p class="text-sm text-muted-foreground">Safe, supervised detox with medical support to manage withdrawal symptoms safely and comfortably.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Psychological Counseling</h4>
            <p class="text-sm text-muted-foreground">Individual and group counseling sessions to address trauma, stress, and behavioral patterns.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Therapy Programs</h4>
            <p class="text-sm text-muted-foreground">Structured therapeutic interventions and skill-building to support long-term recovery.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Aftercare Support</h4>
            <p class="text-sm text-muted-foreground">Ongoing support and relapse prevention strategies for sustained recovery.</p>
          </div>
        </div>

        <h3 class="text-2xl font-semibold mt-10 mb-4">Why Choose Janani for Alcohol Rehabilitation?</h3>

        <ul class="space-y-3 text-muted-foreground mb-8">
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Professional medical team with expertise in addiction medicine</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>24/7 medical supervision and support</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Safe, secure, and confidential environment</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Personalized treatment plans for each individual</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Comfort and dignity maintained throughout treatment</span>
          </li>
        </ul>

        <div class="rounded-3xl border bg-surface p-6 md:p-8">
          <h3 class="text-2xl font-semibold mb-4">Get Help Today</h3>
          <p class="text-muted-foreground mb-6">
            Alcohol addiction is a treatable condition. With proper support and treatment, recovery is possible. Reach out to us today.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="tel:+916302682285" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 font-medium text-primary-foreground hover:opacity-90">
              Call 6302682285
            </a>
            <a href="/contact" class="inline-flex items-center justify-center rounded-full border px-6 py-3 font-medium hover:bg-accent/50">
              Schedule Consultation
            </a>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
