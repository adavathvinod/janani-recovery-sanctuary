---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getServiceLocationSchema } from '@/lib/structured-data';

const structuredData = getServiceLocationSchema(
  "De-Addiction Centre",
  "de-addiction-centre-hayathnagar",
  "Professional de-addiction and rehabilitation centre in Hayathnagar, Hyderabad, Telangana"
);
---

<Layout
  title="Recovery & Wellness Centre in Hayathnagar | Janani Rehabilitation"
  description="Professional recovery centre in Hayathnagar offering evidence-based treatment, medical supervision, counseling, and holistic wellness. Compassionate care for healing and lasting recovery. Call 6302682285."
  keywords="recovery centre hayathnagar, wellness treatment, rehabilitation centre, recovery program, professional support"
  canonicalUrl="/de-addiction-centre-hayathnagar"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/de-addiction-centre-hayathnagar" client:load />

    <section class="bg-hero">
      <div class="container py-14 md:py-20">
        <h1 class="text-4xl md:text-5xl">Recovery & Wellness Centre in Hayathnagar</h1>
        <p class="mt-4 max-w-prose text-lg text-muted-foreground">
          Conveniently located in Hayathnagar. Professional, compassionate recovery care with evidence-based treatment, medical supervision, counseling, and holistic wellness.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="tel:+916302682285" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90">
            Call Now
          </a>
          <a href="https://wa.me/916302682285" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50">
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-18">
      <div class="container max-w-4xl">
        <h2 class="text-3xl font-bold mb-6">Expert Recovery & Wellness Program in Hayathnagar</h2>

        <p class="text-muted-foreground leading-relaxed mb-6">
          Janani is a compassionate recovery sanctuary conveniently located in Hayathnagar, Hyderabad, providing accessible, professional care to individuals across Telangana. We specialize in helping individuals overcome substance-related challenges and rebuild their lives with dignity, confidence, and hope.
        </p>

        <p class="text-muted-foreground leading-relaxed mb-6">
          With easy access from Hayathnagar and surrounding areas, our facility provides professional, evidence-based recovery treatment that combines medical supervision, psychological counseling, and holistic therapeutic support. We understand that recovery is not a weakness—it's a health condition that requires compassionate professional treatment. Our goal is to help individuals and families heal, rebuild relationships, and develop the tools for lasting recovery.
        </p>

        <h3 class="text-2xl font-semibold mt-10 mb-4">Our Comprehensive Recovery Program</h3>

        <div class="grid gap-6 md:grid-cols-2 mb-8">
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Personalized Assessment</h4>
            <p class="text-sm text-muted-foreground">Detailed, compassionate evaluation to understand individual circumstances and develop personalized recovery plans tailored to unique needs.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Safe Medical Supervision</h4>
            <p class="text-sm text-muted-foreground">24/7 professional medical care to manage withdrawal symptoms safely, comfortably, and with dignity throughout the recovery process.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Evidence-Based Therapy</h4>
            <p class="text-sm text-muted-foreground">Professional counseling sessions—individual and group—using proven therapies to address root causes and build healthy coping mechanisms.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Family Support Programs</h4>
            <p class="text-sm text-muted-foreground">Family sessions and involvement throughout recovery to rebuild relationships, increase understanding, and create strong support systems.</p>
          </div>
        </div>

        <h3 class="text-2xl font-semibold mt-10 mb-4">Why Choose Janani Hayathnagar?</h3>

        <ul class="space-y-3 text-muted-foreground mb-8">
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Conveniently located in Hayathnagar with easy access from surrounding areas</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Experienced medical team specializing in compassionate recovery support</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>24/7 availability for admissions, enquiries, and emergency support</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Confidential, secure, and dignified environment for healing</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Evidence-based therapies combined with holistic wellness activities</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Ongoing aftercare and relapse prevention support for sustained recovery</span>
          </li>
        </ul>

        <div class="rounded-3xl border bg-surface p-6 md:p-8">
          <h3 class="text-2xl font-semibold mb-4">Take the First Step Towards Healing</h3>
          <p class="text-muted-foreground mb-6">
            Located conveniently in Hayathnagar, we're ready to help you or your loved one take the first step towards complete recovery and wellness. Reach out today for a confidential, supportive conversation with our experienced team.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="tel:+916302682285" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 font-medium text-primary-foreground hover:opacity-90">
              Call 6302682285
            </a>
            <a href="https://maps.app.goo.gl/cx2M3wCL2MznQouH7" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border px-6 py-3 font-medium hover:bg-accent/50">
              Visit Us
            </a>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
