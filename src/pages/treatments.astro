---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getTreatmentPageSchema } from '@/lib/structured-data';

const structuredData = getTreatmentPageSchema();
---

<Layout
  title="Treatments | Alcohol & Drug Rehabilitation in Hyderabad"
  description="Explore detox, counseling & therapy programs at Janani Rehabilitation Centre in Hyderabad, Telangana. Professional addiction treatment."
  keywords="alcohol detox hyderabad, drug rehabilitation treatment, addiction counseling telangana, therapy programs, detox centre"
  canonicalUrl="/treatments"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/treatments" client:load />

    <section class="py-14 md:py-18">
      <div class="container">
        <h1 class="text-4xl md:text-5xl">Treatments</h1>
        <p class="mt-3 max-w-prose text-muted-foreground">
          Our treatment offerings are designed to support recovery with structure, care and a calm environment.
        </p>

        <div class="mt-8 grid gap-5 md:grid-cols-3">
          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Detox</h2>
            <p class="mt-2 text-sm text-muted-foreground">Supervised detox support to help manage withdrawal and stabilize safely.</p>
          </article>

          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Counseling</h2>
            <p class="mt-2 text-sm text-muted-foreground">Individual and group counseling focused on relapse prevention and life skills.</p>
          </article>

          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Therapy Programs</h2>
            <p class="mt-2 text-sm text-muted-foreground">Structured therapy plans designed to support long-term recovery and emotional wellbeing.</p>
          </article>
        </div>

        <div class="mt-10 rounded-3xl border bg-surface p-6 shadow-soft md:p-8">
          <div class="grid gap-6 md:grid-cols-12 md:items-center">
            <div class="md:col-span-8">
              <h2 class="text-2xl">Ready to talk?</h2>
              <p class="mt-2 text-sm text-muted-foreground">
                Call <span class="text-foreground">8019577648</span> for admissions and quick enquiry.
              </p>
            </div>
            <div class="md:col-span-4 md:flex md:justify-end">
              <div class="flex flex-wrap gap-3">
                <a href="tel:+918019577648" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity">
                  Call Now
                </a>
                <a href="/contact" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
                  Visit Contact
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
