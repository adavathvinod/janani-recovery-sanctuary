---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getTreatmentPageSchema } from '@/lib/structured-data';

const structuredData = getTreatmentPageSchema();
---

<Layout
  title="Wellness Programs in Hyderabad | Janani Wellness Centre"
  description="Explore structured wellness programs, counseling support, healthy routines, wellness activities, and professional guidance at Janani Wellness Centre Hyderabad."
  keywords="wellness programs hyderabad, wellness support, counseling therapy, professional care, wellness support"
  canonicalUrl="/treatments"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/treatments" client:load />

    <section class="py-14 md:py-18">
      <div class="container">
        <h1 class="text-2xl sm:text-3xl md:text-5xl">Professional Wellness Programs</h1>
        <p class="mt-3 max-w-prose text-muted-foreground">
          Our comprehensive wellness programs are designed to support sustainable well-being with professional counseling, wellness activities, structured routines, and compassionate support.
        </p>

        <div class="mt-8 grid gap-5 md:grid-cols-3">
          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Professional Care Planning</h2>
            <p class="mt-2 text-sm text-muted-foreground">24/7 professional support and structured wellness guidance provided by experienced professionals to ensure safe, comfortable, and personalized wellness care.</p>
          </article>

          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Professional Counseling</h2>
            <p class="mt-2 text-sm text-muted-foreground">Individual and group counseling using proven approaches (CBT, Motivational Enhancement) to support emotional well-being, healthy routines, and long-term wellness.</p>
          </article>

          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Holistic Wellness Support</h2>
            <p class="mt-2 text-sm text-muted-foreground">Structured wellness sessions, meditation, yoga, fitness activities, and daily routines to support physical, mental, and emotional balance and overall well-being.</p>
          </article>
        </div>

        <div class="mt-8 grid gap-5 md:grid-cols-3">
          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Supportive Guidance</h2>
            <p class="mt-2 text-sm text-muted-foreground">Supportive communication and guidance to help loved ones better understand wellness challenges and encourage positive wellness routines.</p>
          </article>

          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Personalized Programs</h2>
            <p class="mt-2 text-sm text-muted-foreground">Structured wellness support plans tailored to individual needs, circumstances, and goals for maximum effectiveness and long-term well-being.</p>
          </article>

          <article class="rounded-2xl border bg-card p-6 shadow-soft">
            <h2 class="text-xl">Ongoing Wellness Support</h2>
            <p class="mt-2 text-sm text-muted-foreground">Continued counseling, wellness guidance, structured routines, and supportive follow-up programs focused on long-term well-being and sustainable wellness practices.</p>
          </article>
        </div>

        <div class="mt-12 rounded-2xl border bg-card p-6 md:p-8">
          <h2 class="text-2xl font-semibold mb-4">Our Wellness Environment</h2>
          <p class="text-muted-foreground leading-relaxed">
            Our wellness center includes comfortable accommodation facilities, nutritious meals, professional counseling support, mindfulness and meditation sessions, structured wellness activities, yoga and fitness programs, and carefully designed daily routines. This supportive environment is created to help individuals focus on their wellness journey, develop healthy habits, and build emotional balance in a calm, safe, and respectful setting.
          </p>
        </div>

        <div class="mt-10 rounded-3xl border bg-surface p-6 shadow-soft md:p-8">
          <div class="grid gap-6 md:grid-cols-12 md:items-center">
            <div class="md:col-span-8">
              <h2 class="text-2xl">Ready to Learn More About Our Programs?</h2>
              <p class="mt-2 text-sm text-muted-foreground">
                Our expert team is available 24/7 for consultations, wellness enquiries, and support at <span class="text-foreground font-semibold">6302682285</span>.
              </p>
            </div>
            <div class="md:col-span-4 md:flex md:justify-end">
              <div class="flex flex-wrap gap-3">
                <a href="tel:+916302682285" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity">
                  Call Now
                </a>
                <a href="/contact" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
                  Visit Contact
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
