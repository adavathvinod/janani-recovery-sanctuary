---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getGalleryPageSchema } from '@/lib/structured-data';

const structuredData = getGalleryPageSchema();

const images = [
  { src: "/images/reception-1-hd.jpg", alt: "Reception area" },
  { src: "/images/reception-2-hd.jpg", alt: "Reception and welcome area" },
  { src: "/images/beds-1-hd.jpg", alt: "Comfortable accommodation" },
  { src: "/images/cctv-room-hd.jpg", alt: "Security and monitoring" },
  { src: "/images/buddha-wall-hd.jpg", alt: "Meditation and wellness space" },
  { src: "/images/timetable-hd.jpg", alt: "Daily routine schedule" }
];
---

<Layout
  title="Gallery | Janani Wellness Centre Hyderabad"
  description="View the facilities, wellness environment, accommodation, wellness activities, and supportive spaces at Janani Wellness Centre in Hyderabad."
  keywords="janani gallery, wellness centre photos, wellness facility images, hyderabad"
  canonicalUrl="/gallery"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/gallery" client:load />

    <section class="py-14 md:py-18">
      <div class="container">
        <h1 class="text-2xl sm:text-3xl md:text-5xl">Our Wellness Environment</h1>
        <p class="mt-4 text-lg text-muted-foreground">
          Explore our facilities, accommodation, wellness activities, and peaceful environment designed for sustainable well-being.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {images.map((img) => (
            <div class="photo-frame photo-cinematic overflow-hidden rounded-2xl border shadow-soft">
              <img
                src={img.src}
                alt={img.alt}
                class="img-premium photo-hover aspect-[4/3] w-full object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>

        <div class="mt-12 rounded-3xl border bg-surface p-6 shadow-soft md:p-8">
          <div class="grid gap-6 md:grid-cols-12 md:items-center">
            <div class="md:col-span-8">
              <h2 class="text-2xl font-semibold">Experience Janani</h2>
              <p class="mt-3 text-muted-foreground">
                Visit us in person or call to schedule a tour and meet our team.
              </p>
            </div>
            <div class="md:col-span-4 md:flex md:justify-end">
              <div class="flex flex-wrap gap-3">
                <a href="/contact" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity">
                  Schedule Visit
                </a>
                <a href="https://maps.app.goo.gl/cx2M3wCL2MznQouH7" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
                  Get Directions
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
