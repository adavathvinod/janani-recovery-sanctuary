---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getServiceLocationSchema } from '@/lib/structured-data';

const structuredData = getServiceLocationSchema(
  "Wellness Support",
  "wellness-support-hyderabad",
  "Professional wellness support and care programs in Hyderabad, Telangana"
);
---

<Layout
  title="Wellness Support Centre in Hyderabad | Janani Wellness Centre"
  description="Professional wellness support centre in Hyderabad with evidence-based treatment, professional care, counseling, and holistic wellness. Compassionate care for sustainable well-being. Call 6302682285."
  keywords="wellness support hyderabad, wellness treatment, wellness centre, professional support hyderabad, behavioral wellness"
  canonicalUrl="/drug-rehabilitation-hyderabad"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/drug-recovery-hyderabad" client:load />

    <section class="bg-hero">
      <div class="container py-14 md:py-20">
        <h1 class="text-4xl md:text-5xl">Professional Wellness Support in Hyderabad</h1>
        <p class="mt-4 max-w-prose text-lg text-muted-foreground">
          Professional, compassionate wellness support at Janani. Evidence-based treatment, professional care, counseling, and holistic wellness for sustainable well-being.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="tel:+916302682285" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90">
            Call Now
          </a>
          <a href="https://wa.me/916302682285" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50">
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-18">
      <div class="container max-w-4xl">
        <h2 class="text-3xl font-bold mb-6">Professional Wellness Support Programs in Hyderabad</h2>

        <p class="text-muted-foreground leading-relaxed mb-6">
          Janani is a professional wellness and support sanctuary dedicated to helping individuals and families through evidence-based care and compassionate support. Behavioral wellness challenges affect physical health, mental well-being, relationships, career, and overall quality of life. Our comprehensive program combines evidence-based treatment, professional care planning, and therapeutic support within a safe, structured environment.
        </p>

        <p class="text-muted-foreground leading-relaxed mb-6">
          We understand that recovery is not a weakness—it's a health condition that requires professional treatment and compassionate support. Our expert team of doctors, counselors, and therapists brings years of experience in helping individuals rebuild their lives with confidence, clarity, and hope.
        </p>

        <h3 class="text-2xl font-semibold mt-10 mb-4">Our Comprehensive Recovery Approach</h3>

        <div class="grid gap-6 md:grid-cols-2 mb-8">
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Safe Medical Supervision</h4>
            <p class="text-sm text-muted-foreground">24/7 professional medical care and support to manage withdrawal symptoms safely and comfortably, with monitoring and certified medical staff.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Evidence-Based Counseling</h4>
            <p class="text-sm text-muted-foreground">Individual and group counseling sessions using proven therapies to address underlying causes, rebuild emotional resilience, and develop healthy coping mechanisms.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Holistic Wellness Therapy</h4>
            <p class="text-sm text-muted-foreground">Structured therapeutic programs, meditation, yoga, fitness activities, and wellness routines to support physical and mental healing.</p>
          </div>
          <div class="rounded-2xl border bg-card p-6">
            <h4 class="font-semibold mb-3">Family & Aftercare Support</h4>
            <p class="text-sm text-muted-foreground">Family sessions, relapse prevention strategies, ongoing counseling, and community programs for sustained recovery and strong support systems.</p>
          </div>
        </div>

        <h3 class="text-2xl font-semibold mt-10 mb-4">Why Choose Janani for Drug Recovery?</h3>

        <ul class="space-y-3 text-muted-foreground mb-8">
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Certified doctors, therapists & counselors with extensive recovery support expertise</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>24/7 medical supervision and emergency support always available</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Safe, peaceful, and confidential environment with dignity and respect</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Personalized recovery plans for opioids, marijuana, heroin, cocaine, and other substances</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Evidence-based therapies: CBT, Motivational Enhancement, Mindfulness & Yoga</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Family involvement and support throughout the recovery journey</span>
          </li>
          <li class="flex gap-3">
            <span class="text-primary font-bold">✓</span>
            <span>Focus on long-term healing, confidence, emotional balance, and healthy lifestyle habits</span>
          </li>
        </ul>

        <div class="rounded-3xl border bg-surface p-6 md:p-8">
          <h3 class="text-2xl font-semibold mb-4">Take the First Step Towards Recovery</h3>
          <p class="text-muted-foreground mb-6">
            Recovery is possible with the right professional support and compassionate care. Early intervention supports faster and safer healing, protects family relationships, and prevents health risks. You don't have to face this alone—our experienced team is here to guide and support you at every step.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="tel:+916302682285" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 font-medium text-primary-foreground hover:opacity-90">
              Call 6302682285
            </a>
            <a href="/contact" class="inline-flex items-center justify-center rounded-full border px-6 py-3 font-medium hover:bg-accent/50">
              Schedule Consultation
            </a>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
