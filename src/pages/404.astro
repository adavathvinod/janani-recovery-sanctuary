---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';

---

<Layout
  title="Page Not Found | Janani Rehabilitation Centre"
  description="The page you're looking for could not be found."
  robots="noindex, follow"
  canonicalUrl="/404"
>
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <SiteHeader currentPath="/404" client:load />

    <div class="flex-1 flex items-center justify-center py-20">
      <div class="container max-w-md text-center">
        <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
        <h2 class="text-2xl font-semibold mb-3">Page Not Found</h2>
        <p class="text-muted-foreground mb-8">
          Sorry, the page you're looking for doesn't exist. Please check the URL and try again.
        </p>
        <div class="flex gap-3 justify-center">
          <a href="/" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity">
            Go Home
          </a>
          <a href="/contact" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </div>

    <SiteFooter client:load />
  </div>
</Layout>
