---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
---

<Layout
  title="Privacy Policy | Janani Wellness Centre"
  description="Privacy policy for Janani Wellness Centre. We are committed to protecting your personal data and maintaining confidentiality."
  canonicalUrl="/privacy-policy"
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/privacy-policy" client:load />

    <section class="bg-hero">
      <div class="container py-14 md:py-20">
        <h1 class="text-4xl md:text-5xl">Privacy Policy</h1>
        <p class="mt-4 max-w-prose text-lg text-muted-foreground">
          Last updated: May 2026
        </p>
      </div>
    </section>

    <section class="py-14 md:py-18">
      <div class="container max-w-4xl">
        <div class="prose prose-invert max-w-none space-y-6 text-muted-foreground">
          <h2 class="text-2xl font-semibold text-foreground">1. Introduction</h2>
          <p>
            Janani Wellness Centre ("we," "us," "our," or "Company") is committed to protecting your privacy and ensuring you have a positive experience on our website and when using our services. This Privacy Policy explains how we collect, use, disclose, and safeguard your information.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">2. Information We Collect</h2>
          <p>We may collect information about you in a variety of ways. The information we may collect on the website includes:</p>
          <ul class="list-disc pl-6 space-y-2">
            <li>Personal identification information (name, email address, phone number)</li>
            <li>Contact information provided through inquiry forms</li>
            <li>Information you voluntarily provide when contacting us</li>
            <li>Browser and device information</li>
            <li>Usage data and analytics</li>
          </ul>

          <h2 class="text-2xl font-semibold text-foreground">3. Use of Your Information</h2>
          <p>Having accurate information about you permits us to provide you with a smooth, efficient, and customized experience. Specifically, we may use information collected about you via the website to:</p>
          <ul class="list-disc pl-6 space-y-2">
            <li>Process and respond to your inquiries</li>
            <li>Send you promotional communications (with consent)</li>
            <li>Improve our website and services</li>
            <li>Generate analytics about our website usage</li>
            <li>Monitor and analyze trends, usage, and activities</li>
          </ul>

          <h2 class="text-2xl font-semibold text-foreground">4. Confidentiality & Data Protection</h2>
          <p>
            We implement appropriate technical and organizational measures to maintain the security of your personal information. Your information is kept confidential and is only accessed by authorized personnel. We do not sell, trade, or rent your personal identification information to others.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">5. Third-Party Links</h2>
          <p>
            Our website may contain links to third-party websites. We are not responsible for the privacy practices of these external sites. We encourage you to review their privacy policies before providing any information.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">6. Cookies & Tracking Technologies</h2>
          <p>
            We use cookies and similar tracking technologies to enhance your experience on our website. You can control cookie settings through your browser preferences. Some functionality may be limited if cookies are disabled.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">7. Your Rights</h2>
          <p>You have the right to:</p>
          <ul class="list-disc pl-6 space-y-2">
            <li>Access the personal information we hold about you</li>
            <li>Request correction of inaccurate information</li>
            <li>Request deletion of your information</li>
            <li>Opt-out of promotional communications</li>
          </ul>

          <h2 class="text-2xl font-semibold text-foreground">8. Contact Us</h2>
          <p>
            If you have any questions about this Privacy Policy or our privacy practices, please contact us at:
          </p>
          <div class="bg-surface rounded-2xl p-6 mt-4">
            <p class="font-semibold">Janani Wellness Centre</p>
            <p>Phone: 6302682285</p>
            <p>Email: jananiwellness@gmail.com</p>
            <p>Address: Hayathnagar, Hyderabad, Telangana 501505</p>
          </div>

          <h2 class="text-2xl font-semibold text-foreground">9. Changes to Privacy Policy</h2>
          <p>
            We reserve the right to modify this Privacy Policy at any time. Changes will be effective immediately upon posting to the website. Your continued use of the website following the posting of revised Privacy Policy means that you accept and agree to the changes.
          </p>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
