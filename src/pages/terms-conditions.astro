---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
---

<Layout
  title="Terms & Conditions | Janani Wellness Centre"
  description="Terms and conditions for using Janani Wellness Centre website and services."
  canonicalUrl="/terms-conditions"
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/terms-conditions" client:load />

    <section class="bg-hero">
      <div class="container py-14 md:py-20">
        <h1 class="text-4xl md:text-5xl">Terms & Conditions</h1>
        <p class="mt-4 max-w-prose text-lg text-muted-foreground">
          Last updated: May 2026
        </p>
      </div>
    </section>

    <section class="py-14 md:py-18">
      <div class="container max-w-4xl">
        <div class="prose prose-invert max-w-none space-y-6 text-muted-foreground">
          <h2 class="text-2xl font-semibold text-foreground">1. Terms of Use</h2>
          <p>
            These Terms and Conditions govern your use of the Janani Wellness Centre website and the services provided. By accessing and using this website, you accept and agree to be bound by the terms and provision of this agreement.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">2. Use License</h2>
          <p>
            Permission is granted to temporarily download one copy of the materials (information or software) on Janani Wellness Centre's website for personal, non-commercial transitory viewing only. This is the grant of a license, not a transfer of title, and under this license you may not:
          </p>
          <ul class="list-disc pl-6 space-y-2">
            <li>Modify or copy the materials</li>
            <li>Use the materials for any commercial purpose or for any public display</li>
            <li>Attempt to decompile or reverse engineer any software contained on the website</li>
            <li>Remove any copyright or other proprietary notations from the materials</li>
            <li>Transfer the materials to another person or "mirror" the materials on any other server</li>
          </ul>

          <h2 class="text-2xl font-semibold text-foreground">3. Disclaimer of Warranties</h2>
          <p>
            The materials on Janani Wellness Centre's website are provided on an 'as is' basis. Janani Wellness Centre makes no warranties, expressed or implied, and hereby disclaims and negates all other warranties including, without limitation, implied warranties or conditions of merchantability, fitness for a particular purpose, or non-infringement of intellectual property or other violation of rights.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">4. Limitations of Liability</h2>
          <p>
            In no event shall Janani Wellness Centre or its suppliers be liable for any damages (including, without limitation, damages for loss of data or profit, or due to business interruption) arising out of the use or inability to use the materials on the website.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">5. Accuracy of Materials</h2>
          <p>
            The materials appearing on Janani Wellness Centre's website could include technical, typographical, or photographic errors. Janani Wellness Centre does not warrant that any of the materials on the website are accurate, complete, or current. We may make changes to the materials contained on the website at any time without notice.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">6. Links and External Sites</h2>
          <p>
            Janani Wellness Centre has not reviewed all of the sites linked to its website and is not responsible for the contents of any such linked site. The inclusion of any link does not imply endorsement by Janani Wellness Centre of the site. Use of any such linked website is at the user's own risk.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">7. Modifications</h2>
          <p>
            Janani Wellness Centre may revise these terms of service for the website at any time without notice. By using this website, you are agreeing to be bound by the then current version of these terms of service.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">8. Governing Law</h2>
          <p>
            These terms and conditions are governed by and construed in accordance with the laws of India, and you irrevocably submit to the exclusive jurisdiction of the courts located in Hyderabad, Telangana.
          </p>

          <h2 class="text-2xl font-semibold text-foreground">9. Contact Information</h2>
          <p>
            If you have any questions about these Terms and Conditions, please contact us at:
          </p>
          <div class="bg-surface rounded-2xl p-6 mt-4">
            <p class="font-semibold">Janani Wellness Centre</p>
            <p>Phone: 6302682285</p>
            <p>Email: jananiwellness@gmail.com</p>
            <p>Address: Hayathnagar, Hyderabad, Telangana 501505</p>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
