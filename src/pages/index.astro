---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getCompleteHomeSchema } from '@/lib/structured-data';

const homeFaqs = [
  {
    question: "What is Janani Rehabilitation Centre?",
    answer: "Janani Alcohol & Drug Rehabilitation Centre is a professional addiction treatment facility in Hyderabad, Telangana, offering comprehensive care including detoxification, counseling, therapy, and holistic support for recovery."
  },
  {
    question: "What treatments does Janani offer?",
    answer: "We offer alcohol detoxification, drug rehabilitation, individual and group counseling, structured therapy programs, and wellness support designed to support long-term recovery."
  },
  {
    question: "Where is Janani located?",
    answer: "Janani is located in Hayathnagar, Hyderabad, Telangana. We serve patients from Hyderabad, Hayathnagar, LB Nagar, Dilsukhnagar, Miryalaguda, Suryapet, Khammam, Nalgonda, and all of Telangana."
  },
  {
    question: "How can I contact Janani for admissions?",
    answer: "You can reach us at 8019577648, via WhatsApp at +918019577648, or email jananirehabilition@gmail.com. We offer fast response times for all enquiries."
  }
];

const faqSchema = {
  "@type": "FAQPage",
  "@id": "https://jananideaddiction.com/#faq",
  "mainEntity": homeFaqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const siteNavigationSchema = {
  "@type": "SiteNavigationElement",
  "@id": "https://jananideaddiction.com/#site-navigation",
  "name": [
    "Home",
    "About",
    "Treatments",
    "Gallery",
    "Contact"
  ],
  "url": [
    "https://jananideaddiction.com/",
    "https://jananideaddiction.com/about",
    "https://jananideaddiction.com/treatments",
    "https://jananideaddiction.com/gallery",
    "https://jananideaddiction.com/contact"
  ]
};

const baseSchema = getCompleteHomeSchema();
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    ...(baseSchema["@graph"] ?? []),
    siteNavigationSchema,
    faqSchema
  ]
};
---

<Layout
  title="Janani Rehabilitation Centre | Best De-Addiction Centre in Hyderabad, Telangana"
  description="Janani Alcohol & Drug Rehabilitation Centre offers professional addiction treatment, detox, counseling & therapy in Hyderabad. Serving Hayathnagar, LB Nagar, Dilsukhnagar & all Telangana. Call 8019577648."
  keywords="rehabilitation centre hyderabad, de-addiction centre telangana, alcohol rehabilitation, drug rehabilitation, addiction treatment hyderabad"
  canonicalUrl="/"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/" client:load />

    <!-- Hero Section -->
    <section class="bg-hero">
      <div class="container grid gap-10 py-14 md:grid-cols-12 md:items-center md:py-20">
        <div class="md:col-span-6">
          <p class="inline-flex items-center gap-2 rounded-full border bg-background/70 px-3 py-1 text-xs font-medium text-muted-foreground shadow-soft">
            Hyderabad • Premium Recovery & Healing
          </p>
          <h1 class="mt-5 text-4xl leading-[1.05] md:text-6xl">A New Beginning, A Better Life.</h1>
          <p class="mt-4 max-w-prose text-lg text-muted-foreground md:text-xl">
            Hyderabad's Premier Sanctuary for Recovery & Healing.
          </p>

          <div class="mt-7 flex flex-wrap items-center gap-3">
            <a href="tel:+918019577648" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity">
              Call Now
            </a>
            <a href="https://wa.me/918019577648" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border border-primary px-6 py-3 text-sm font-medium text-primary hover:bg-primary/10 transition-colors">
              WhatsApp
            </a>
            <a href="/treatments" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
              Explore Treatments
            </a>
          </div>

          <div class="mt-8 grid gap-4 rounded-2xl border bg-background/70 p-5 shadow-soft md:grid-cols-3">
            <div>
              <div class="text-sm font-semibold">Discreet care</div>
              <div class="text-xs text-muted-foreground">Professional, respectful & confidential.</div>
            </div>
            <div>
              <div class="text-sm font-semibold">Structured routine</div>
              <div class="text-xs text-muted-foreground">Stability that supports long-term recovery.</div>
            </div>
            <div>
              <div class="text-sm font-semibold">Trusted environment</div>
              <div class="text-xs text-muted-foreground">Safety-first, calming, clean spaces.</div>
            </div>
          </div>
        </div>

        <div class="md:col-span-6">
          <div class="photo-frame photo-cinematic">
            <img
              src="/images/reception-2-hd.jpg"
              alt="Janani rehabilitation centre reception area"
              class="img-premium photo-hover aspect-[4/3] w-full object-cover"
              loading="eager"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-background/60 via-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4 rounded-2xl border bg-background/75 p-4 shadow-soft backdrop-blur">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <div class="text-sm font-semibold">Admissions & Enquiry</div>
                  <div class="text-xs text-muted-foreground">Call 8019577648 • Fast response</div>
                </div>
                <div class="hidden sm:block">
                  <a href="tel:+918019577648" class="inline-flex items-center justify-center rounded-full bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:opacity-90">
                    Call
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Badges -->
    <section class="border-y bg-surface py-8">
      <div class="container">
        <div class="grid gap-4 md:grid-cols-3">
          <article class="flex items-start gap-4 rounded-2xl border bg-background p-5 shadow-soft">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl border bg-accent text-accent-foreground shadow-soft">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
              <h2 class="text-base font-semibold text-foreground">24/7 CCTV</h2>
              <p class="mt-1 text-sm text-muted-foreground">Safety-first environment with continuous monitoring.</p>
            </div>
          </article>

          <article class="flex items-start gap-4 rounded-2xl border bg-background p-5 shadow-soft">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl border bg-accent text-accent-foreground shadow-soft">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.172l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            </div>
            <div>
              <h2 class="text-base font-semibold text-foreground">Medical Supervision</h2>
              <p class="mt-1 text-sm text-muted-foreground">Structured care guided by trained professionals.</p>
            </div>
          </article>

          <article class="flex items-start gap-4 rounded-2xl border bg-background p-5 shadow-soft">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl border bg-accent text-accent-foreground shadow-soft">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <div>
              <h2 class="text-base font-semibold text-foreground">Confidential Support</h2>
              <p class="mt-1 text-sm text-muted-foreground">Discreet admissions with respectful communication.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Amenities Section -->
    <section class="py-14 md:py-18">
      <div class="container">
        <div class="flex items-end justify-between gap-6">
          <div>
            <h2 class="text-3xl md:text-4xl">High-Class Amenities</h2>
            <p class="mt-2 max-w-prose text-muted-foreground">
              A tranquil, professional environment designed for comfort, safety and healing.
            </p>
          </div>
          <a href="/gallery" class="hidden md:inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
            View Gallery
          </a>
        </div>

        <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          <article class="group rounded-2xl border bg-card p-5 shadow-soft transition-transform hover:-translate-y-0.5">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl border bg-accent text-accent-foreground shadow-soft">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 16l4-4m0 0l4 4m-4-4v4"></path></svg>
            </div>
            <h3 class="mt-4 text-lg">Luxury Living</h3>
            <p class="mt-1 text-sm text-muted-foreground">Premium high-class beds and spacious rooms.</p>
          </article>

          <article class="group rounded-2xl border bg-card p-5 shadow-soft transition-transform hover:-translate-y-0.5">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl border bg-accent text-accent-foreground shadow-soft">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
            </div>
            <h3 class="mt-4 text-lg">Nutrition</h3>
            <p class="mt-1 text-sm text-muted-foreground">In-house kitchen providing healthy, balanced meals.</p>
          </article>

          <article class="group rounded-2xl border bg-card p-5 shadow-soft transition-transform hover:-translate-y-0.5">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl border bg-accent text-accent-foreground shadow-soft">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m7 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="mt-4 text-lg">Safety</h3>
            <p class="mt-1 text-sm text-muted-foreground">24/7 CCTV surveillance for a secure environment.</p>
          </article>

          <article class="group rounded-2xl border bg-card p-5 shadow-soft transition-transform hover:-translate-y-0.5">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl border bg-accent text-accent-foreground shadow-soft">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="mt-4 text-lg">Recreation</h3>
            <p class="mt-1 text-sm text-muted-foreground">Large open/free space for meditation and movement.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Gallery Preview -->
    <section class="py-14 md:py-18 border-t">
      <div class="container">
        <div class="grid gap-10 lg:grid-cols-12 lg:items-center">
          <div class="lg:col-span-7">
            <div class="photo-frame photo-cinematic">
              <img src="/images/beds-1-hd.jpg" alt="Spacious accommodation with premium beds" class="img-premium photo-hover aspect-[4/3] w-full object-cover" loading="lazy" />
            </div>
          </div>
          <div class="lg:col-span-5">
            <div class="grid gap-4">
              <div class="photo-frame photo-cinematic shadow-soft">
                <img src="/images/cctv-room-hd.jpg" alt="Security monitoring and CCTV safety" class="img-premium photo-hover aspect-[4/3] w-full object-cover" loading="lazy" />
              </div>
              <div class="photo-frame photo-cinematic shadow-soft">
                <img src="/images/buddha-wall-hd.jpg" alt="Meditation and wellness ambience" class="img-premium photo-hover aspect-[4/3] w-full object-cover" loading="lazy" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-14 md:py-18">
      <div class="container">
        <div class="flex items-end justify-between gap-6">
          <div>
            <h2 class="text-3xl md:text-4xl">Testimonials</h2>
            <p class="mt-2 max-w-prose text-muted-foreground">
              Realistic recovery journeys—focused on safety, structure, and support.
            </p>
          </div>
          <a href="/contact" class="hidden md:inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
            Talk to Us
          </a>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-3">
          <figure class="rounded-3xl border bg-card p-6 shadow-soft">
            <blockquote class="text-sm leading-relaxed text-foreground">"Before: our home was in constant fear and uncertainty. After: we saw stability return — calm routines, respectful counseling, and real hope for the future."</blockquote>
            <figcaption class="mt-4 text-sm font-semibold text-foreground">Parent of a Patient</figcaption>
            <p class="mt-1 text-xs text-muted-foreground">Verified enquiry feedback (anonymized).</p>
          </figure>

          <figure class="rounded-3xl border bg-card p-6 shadow-soft">
            <blockquote class="text-sm leading-relaxed text-foreground">"Before: I felt stuck and isolated. After: the structured routine, supportive team, and peaceful environment helped me rebuild confidence—one day at a time."</blockquote>
            <figcaption class="mt-4 text-sm font-semibold text-foreground">Recovered Client</figcaption>
            <p class="mt-1 text-xs text-muted-foreground">Verified enquiry feedback (anonymized).</p>
          </figure>

          <figure class="rounded-3xl border bg-card p-6 shadow-soft">
            <blockquote class="text-sm leading-relaxed text-foreground">"Before: we didn't know where to start. After: clear guidance, confidential support, and fast responses made the process feel safe and manageable."</blockquote>
            <figcaption class="mt-4 text-sm font-semibold text-foreground">Family Member</figcaption>
            <p class="mt-1 text-xs text-muted-foreground">Verified enquiry feedback (anonymized).</p>
          </figure>
        </div>
      </div>
    </section>

    <!-- Treatment Programs CTA -->
    <section class="border-t bg-surface py-14 md:py-18">
      <div class="container">
        <div class="grid gap-8 md:grid-cols-12 md:items-center">
          <div class="md:col-span-6">
            <h2 class="text-3xl md:text-4xl">Treatment Programs</h2>
            <p class="mt-3 text-muted-foreground">
              We support recovery through structured care with detox, counseling and therapy programs.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/treatments" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity">
                See Treatments
              </a>
              <a href="/contact" class="inline-flex items-center justify-center rounded-full border px-6 py-3 text-sm font-medium hover:bg-accent/50 transition-colors">
                Get Directions
              </a>
            </div>
          </div>
          <div class="md:col-span-6">
            <div class="rounded-3xl border bg-background p-6 shadow-soft">
              <h3 class="text-xl">Visit Us</h3>
              <p class="mt-2 text-sm text-muted-foreground">No.4 Block, 2nd Floor, Plot No.2, Survey No.268, Word, Street No. 7, Hayathnagar_Khalsa, Hyderabad, Telangana 501505</p>
              <div class="mt-4 flex flex-wrap gap-3">
                <a href="https://maps.app.goo.gl/cx2M3wCL2MznQouH7" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border bg-background px-6 py-2 text-sm font-medium hover:bg-accent/50 transition-colors">
                  Open Google Maps
                </a>
                <a href="https://wa.me/918019577648" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border px-6 py-2 text-sm font-medium hover:bg-accent/50 transition-colors">
                  WhatsApp Enquiry
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
