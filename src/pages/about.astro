---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import SiteHeader from '@/components/site/SiteHeader';
import SiteFooter from '@/components/site/SiteFooter';
import FloatingActions from '@/components/site/FloatingActions';
import { getAboutPageSchema } from '@/lib/structured-data';

const structuredData = getAboutPageSchema();
---

<Layout
  title="About Janani Wellness Centre | Compassionate Wellness Support"
  description="Learn about Janani Wellness Centre, our professional wellness programs, structured support approach, compassionate care, and safe wellness environment in Hyderabad."
  keywords="about janani wellness centre, wellness sanctuary, wellness mission, professional support, wellness approach telangana"
  canonicalUrl="/about"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader currentPath="/about" client:load />

    <section class="bg-hero">
      <div class="container grid gap-10 py-14 md:grid-cols-12 md:items-center md:py-20">
        <div class="md:col-span-6">
          <h1 class="text-4xl md:text-5xl">About Janani Wellness Centre</h1>
          <p class="mt-4 text-lg text-muted-foreground">
            Janani is a professional wellness and support sanctuary dedicated to providing structured wellness support, professional guidance, and compassionate care for individuals seeking long-term well-being. We provide structured wellness programs, professional guidance, and holistic wellness support within a calm, peaceful, and respectful environment.
          </p>
          <div class="mt-6 grid gap-4 rounded-2xl border bg-background/70 p-5 shadow-soft">
            <div>
              <div class="text-sm font-semibold">Our Mission</div>
              <div class="text-sm text-muted-foreground">To provide professional wellness support that helps individuals build healthier routines, emotional balance, and long-term well-being with dignity and confidence.</div>
            </div>
            <div>
              <div class="text-sm font-semibold">Our Philosophy</div>
              <div class="text-sm text-muted-foreground">
                Wellness challenges are health conditions requiring professional support and compassion. We provide a balanced approach combining professional wellness care, evidence-based therapy, structured wellness routines, and supportive guidance.
              </div>
            </div>
          </div>
        </div>
        <div class="md:col-span-6">
          <div class="overflow-hidden rounded-3xl border bg-card shadow-elevated">
            <img src="/images/buddha-wall-hd.jpg" alt="Wellness ambience at Janani" class="aspect-[4/3] w-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-18">
      <div class="container max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-foreground mb-6">Our Commitment to Professional Wellness Support</h2>
        <p class="text-muted-foreground leading-relaxed mb-4">
          At Janani, we understand that wellness challenges affect individuals emotionally, mentally, physically, and socially. Meaningful wellness support requires professional care, compassionate psychological support, and a safe, peaceful environment for healing.
        </p>
        <p class="text-muted-foreground leading-relaxed mb-4">
          Our team of certified professionals, therapists, and counselors is dedicated to providing personalized wellness plans that address the unique physical, emotional, and psychological needs of each individual. We combine professional wellness care, therapeutic approaches (CBT, Motivational Enhancement, Mindfulness), professional care planning, wellness activities, and wellness-focused guidance for comprehensive support.
        </p>
        <p class="text-muted-foreground leading-relaxed mb-4">
          Through structured professional care, evidence-based guidance, and compassionate support, we help individuals rebuild confidence, develop healthy coping mechanisms, and establish a foundation for long-term wellness and sustainable practices.
        </p>
        <p class="text-muted-foreground leading-relaxed mb-4">
          Our wellness environment includes comfortable accommodation facilities, nutritious meals, evidence-based counseling support, mindfulness practices, wellness activities, and structured daily routines designed to encourage emotional balance, healthy habits, and long-term well-being. This comprehensive approach creates the foundation for sustainable wellness.
        </p>
        <p class="text-muted-foreground leading-relaxed mb-4">
          Our facilities are designed to provide a safe, clean, peaceful, and secure environment where individuals can focus on wellness, emotional balance, and healthier daily routines in a calm and supportive environment. We maintain strict confidentiality and treat all individuals with respect, dignity, and kindness.
        </p>
      </div>
    </section>

    <SiteFooter client:load />
    <FloatingActions client:load />
  </div>
</Layout>
